{
  "name": "copilot-chat-to-markdown",
  "publisher": "copilot-pkm-bridge",
  "displayName": "Copilot Chat to Markdown",
  "description": "Export GitHub Copilot chat history (JSON/JSONL) to Markdown. Ideal for Obsidian, Notion, or archiving.",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.109.0"
  },
  "keywords": [
    "copilot",
    "chat",
    "markdown",
    "export",
    "jsonl",
    "history",
    "obsidian",
    "pkm"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilot-pkm-bridge.exportChat",
        "title": "Export Copilot Chat: All Workspaces",
        "category": "Copilot Export"
      },
      {
        "command": "copilot-pkm-bridge.exportChatCurrent",
        "title": "Export Copilot Chat: Current Workspace",
        "category": "Copilot Export"
      },
      {
        "command": "copilot-pkm-bridge.exportAllToWingman",
        "title": "Export Copilot Chat: Backup to .wingman (Bulk Export)",
        "category": "Copilot Export"
      },
      {
        "command": "copilot-pkm-bridge.convertFile",
        "title": "Export Copilot Chat: Convert JSON/JSONL File...",
        "category": "Copilot Export"
      }
    ],
    "configuration": {
      "title": "Copilot Chat to Markdown",
      "properties": {
        "copilot-pkm-bridge.defaultExportFolder": {
          "type": "string",
          "default": "${workspaceFolder}/.docs/ai-logs",
          "description": "Default folder to save exported chats. Supports ${workspaceFolder} and ${userHome}."
        },
        "copilot-pkm-bridge.includeMetadata": {
          "type": "boolean",
          "default": true,
          "description": "Include metadata (model, date, etc.) in the exported Markdown."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
